{
  "manifest_version": 3,
  "name": "Seam",
  "version": "1.0.0",
  "description": "Track and manage group projects for corporations and schools",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "tabs",
    "alarms",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
